    {
      "type": "register",
      "direction": "both",
      "port": "scalar_reg",
      "width": 32,
      "description": "Scalar register file read (2*N ports) and write (N ports) interface."
    },
    {
      "type": "register",
      "direction": "both",
      "port": "fp_reg",
      "width": 32,
