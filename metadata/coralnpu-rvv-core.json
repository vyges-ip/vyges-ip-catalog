  "architecture": {
    "type": "coprocessor",
    "isa": "RISC-V Vector Extension 1.0 (Zve32x + optional Zve32f)",
    "features": [
      "Full RVV 1.0 integer vector support (Zve32x)",
      "Optional floating-point vector (Zve32f with 2 FMA units)",
      "Configurable VLEN: 128, 256, 512, or 1024 bits",
      "SEW support: 8, 16, 32, 64-bit element widths",
      "LMUL register grouping: 1/8 through 8",
      "Multi-lane dispatch (4 lanes default)",
      "Out-of-order execution with 8-entry reorder buffer",
      "2 ALU units (add/sub/logic/shift/compare/mask)",
      "2 multiply-accumulate units (widening/narrowing)",
      "1 division unit",
      "1 permutation/reduction unit (gather, slide, compress, reduce)",
      "2 load/store units (unit-stride, strided, indexed)",
      "vsetvli/vsetivli/vsetvl configuration instruction handling",
      "Mask-agnostic and tail-agnostic modes",
      "Vector rounding mode (vxrm) support"
    ]
  },
