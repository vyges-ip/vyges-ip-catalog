      "type": "csr",
      "direction": "both",
      "port": "rvv_csr",
      "description": "Vector CSR interface: vstart, vxrm, vxsat input; config state output."
    },
    {
      "type": "retire",
      "direction": "output",
      "port": "rob2rt",
      "description": "4 ROB-to-retire write ports per lane with write address, data, type."
