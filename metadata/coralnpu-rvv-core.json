      "type": "clock",
      "direction": "input",
      "port": "clk",
      "description": "System clock."
    },
    {
      "type": "reset",
      "direction": "input",
      "port": "rst_n",
      "polarity": "active_low",
      "description": "Asynchronous active-low reset."
    }
  ],
