  "architecture": {
    "type": "peripheral",
    "features": [
      "NIST P-384 (secp384r1) elliptic curve operations",
      "ECDSA key generation, signing, and verification",
      "ECDH shared key computation (Diffie-Hellman)",
      "Public key validation",
      "RFC 6979 deterministic ECDSA with HMAC-DRBG",
      "Radix-48 pipelined Montgomery multiplier with PE array",
      "Point randomization via projective coordinates (Coron CHES 1999)",
      "192-bit scalar blinding (k' = k + r * group_order)",
      "Signature masking (split computation with random d)",
      "True dual-port RAM for register file storage",
      "DSP multiplier support for FPGA (ecc_mult_dsp)",
      "Micro-operation sequencer for complex operations"
    ]
