  "vyges_overlays": [
    {
      "path": "vyges-overlays/uart_reg_top.sv",
      "replaces": "rtl/uart_reg_top.sv",
      "reason": "Upstream tie-off `assign unused_policy_sel = ^racl_policies_i;` uses a struct-level XOR reduction that Vivado 2025.2 rejects with `[Synth 8-2158] illegal operand for operator ^`. Replaced with `assign unused_policy_sel = 1'b0;` which RACL-disabled builds accept cleanly. See vyges-overlays/README.md for the diff."
    }
