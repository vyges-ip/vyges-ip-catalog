  "maintainers": [
    {
      "name": "Vyges",
      "email": "team@vyges.com",
      "url": "https://vyges.com",
      "github": "vyges"
    }
  ],
  "interfaces": [
    {
      "type": "bus",
      "direction": "slave",
      "protocol": "TL-UL",
      "port": "tl",
      "width": 32,
      "description": "Caliptra TileLink-UL slave. Register-based control and data interface for key, IV, data input/output, and status."
    },
    {
      "type": "sideload",
      "direction": "input",
      "protocol": "keymgr",
      "port": "keymgr_key_i",
      "width": 256,
      "description": "Key Manager sideload interface. Hardware key injection without exposing key material to software."
    },
    {
      "type": "entropy",
      "direction": "both",
      "protocol": "EDN",
      "port": "edn",
      "description": "Entropy Distribution Network interface for PRNG reseeding. Separate clock domain (clk_edn_i/rst_edn_ni)."
    },
    {
      "type": "interrupt",
      "direction": "output",
      "protocol": "alert",
      "port": "alert_tx_o",
      "width": 2,
      "description": "Two alerts: fatal_fault (integrity/FSM error) and recov_ctrl_update_err (shadowed register mismatch)."
    },
    {
      "type": "clock",
      "direction": "input",
      "port": "clk_i",
      "description": "Main clock input."
    },
    {
      "type": "reset",
      "direction": "input",
      "port": "rst_ni",
      "polarity": "active_low",
      "description": "Asynchronous active-low reset."
    },
    {
      "type": "control",
      "direction": "input",
      "protocol": "caliptra",
      "port": "caliptra2aes",
      "description": "Caliptra control signals: KeyVault enable, key release size, clear secrets."
    },
    {
      "type": "status",
      "direction": "output",
      "protocol": "caliptra",
      "port": "aes2caliptra",
      "description": "Caliptra status signals: KeyVault data out, key in use, ECB decrypt operation."
    }
  ],
  "parameters": [
    {
      "name": "AES192Enable",
      "type": "bit",
      "default": 1,
      "description": "Enable AES-192 key length support. Set to 0 to save area."
    },
    {
      "name": "AESGCMEnable",
      "type": "bit",
      "default": 1,
      "description": "Enable GCM mode with hardware GHASH. Set to 0 to save area."
    },
    {
      "name": "SecMasking",
      "type": "bit",
      "default": 1,
      "description": "Enable first-order Boolean masking of cipher core for SCA resistance."
    },
    {
      "name": "SecSBoxImpl",
      "type": "enum",
      "default": "SBoxImplDom",
      "description": "S-Box implementation: SBoxImplLut, SBoxImplCanright, SBoxImplCanrightMasked, SBoxImplCanrightMaskedNoreuse, SBoxImplDom."
    },
    {
      "name": "SecStartTriggerDelay",
      "type": "int",
      "default": 0,
      "description": "Configurable delay for SCA measurement trigger."
    },
    {
      "name": "SecAllowForcingMasks",
      "type": "bit",
      "default": 0,
      "description": "Allow forcing mask values via register for SCA evaluation."
    },
    {
      "name": "SecSkipPRNGReseeding",
      "type": "bit",
      "default": 0,
      "description": "Skip PRNG reseeding for SCA testing (not for production)."
    }
  ],
  "performance": {
    "latency": {
      "unmasked_aes128": "12 cycles per 128-bit block",
      "unmasked_aes192": "14 cycles per 128-bit block",
      "unmasked_aes256": "16 cycles per 128-bit block",
      "dom_aes128": "56 cycles per 128-bit block",
      "dom_aes192": "66 cycles per 128-bit block",
      "dom_aes256": "72 cycles per 128-bit block"
    },
    "sbox_parallelism": 16,
    "data_width": 128,
    "key_widths": [
      128,
      192,
      256
    ]
  },
  "architecture": {
    "type": "peripheral",
    "features": [
      "AES-128/192/256 encryption and decryption",
      "ECB, CBC, CFB-128, OFB, CTR cipher block modes",
      "GCM authenticated encryption with hardware GHASH",
      "First-order Domain-Oriented Masking (DOM) for SCA resistance",
      "16 parallel S-Boxes per round",
      "On-the-fly round-key generation",
      "Trivium-based PRNG for masking with configurable reseed rate",
      "LFSR-based PRNG for clearing/zeroization",
      "Sparse FSM encoding (N/P complementary pairs) for fault injection resistance",
      "Shadowed control registers for glitch detection",
      "Key Manager sideload (hardware key injection)",
      "Caliptra KeyVault read/write integration",
      "EDN entropy interface with dual-clock FIFO",
      "Lifecycle escalation response",
      "Automatic and manual trigger modes"
    ]
  },
