  "name": "caliptra-aes",
  "version": "0.1.0",
  "description": "AES-128/192/256 cryptographic accelerator supporting ECB, CBC, CFB-128, OFB, CTR, and GCM (authenticated encryption with GHASH) modes. Features first-order Domain-Oriented Masking (DOM) for side-channel resistance, EDN entropy interface for PRNG reseeding, Key Manager sideload, and Caliptra KeyVault integration. Caliptra TL-UL slave interface. Extracted from CHIPS Alliance Caliptra Root of Trust.",
  "license": "Apache-2.0",
  "maturity": "production",
  "target": [
    "asic",
    "fpga"
  ],
  "design_type": [
    "digital"
