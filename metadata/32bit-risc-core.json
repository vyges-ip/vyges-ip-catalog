  "interfaces": [
    {
      "type": "bus",
      "direction": "output",
      "protocol": "AXI-Lite",
      "port": "imem",
      "width": 32,
      "description": "Instruction fetch AXI-Lite master port (read-only). Signals: imem_arvalid_o, imem_arready_i, imem_araddr_o, imem_rvalid_i, imem_rready_o, imem_rdata_i."
    },
    {
      "type": "bus",
      "direction": "output",
      "protocol": "AXI-Lite",
      "port": "dmem",
      "width": 32,
      "description": "Data load/store AXI-Lite master port with byte enables and write strobe. Full AXI-Lite write channel (AW+W+B) and read channel (AR+R)."
    },
    {
      "type": "interrupt",
      "direction": "input",
      "protocol": "level",
      "port": "irq_i",
      "width": 4,
      "description": "External interrupt inputs. Width configurable via IRQ_LINES parameter (1-16)."
    },
    {
      "type": "clock",
      "direction": "input",
      "port": "clk_i",
      "description": "Main clock input."
    },
    {
      "type": "reset",
      "direction": "input",
      "port": "rst_cold_n_i",
      "polarity": "active_low",
      "description": "Cold reset (power-on reset). Combined with rst_warm_n_i via internal synchronizer."
    },
    {
      "type": "reset",
      "direction": "input",
      "port": "rst_warm_n_i",
      "polarity": "active_low",
      "description": "Warm reset (software-triggered). Combined with rst_cold_n_i via internal synchronizer."
    },
    {
      "type": "debug",
      "direction": "output",
      "port": "commit",
      "description": "Commit/debug interface: commit_pc_o (32-bit), commit_valid_o, exception_o."
    }
  ],
  "parameters": [
    {
      "name": "BP_ENTRIES",
      "type": "int",
      "default": 64,
      "range": "16-256",
      "description": "Branch predictor table depth. Single-bit history per entry, indexed by PC[7:2]. Power of 2 recommended."
    },
    {
      "name": "IRQ_LINES",
      "type": "int",
      "default": 4,
      "range": "1-16",
      "description": "Number of external interrupt input lines."
    },
    {
      "name": "RESET_VECTOR",
      "type": "int",
      "default": "0x00010000",
      "description": "Boot address. PC is set to this value on reset."
    },
    {
      "name": "HAS_MUL",
      "type": "bool",
      "default": true,
      "description": "Enable 16x16 complex multiplier. When false, MUL opcode raises an illegal instruction exception."
    }
  ],
