  "architecture": {
    "type": "processor",
    "isa": "Custom Stanford RISC (32-bit fixed-width)",
    "microarchitecture": "5-stage in-order pipeline, single-issue",
    "features": [
      "Harvard architecture (separate instruction and data buses)",
      "Single-bit branch predictor with configurable table depth",
      "Full data forwarding (EX-to-EX, MEM-to-EX bypasses)",
      "Aligned memory enforcement with precise exceptions",
      "16x16 complex multiplier with overflow detection",
      "CSR register file for status and control",
      "Dual reset (cold + warm) with internal synchronizer",
      "Commit/debug interface for trace and verification"
    ],
    "instruction_formats": [
      "R-type: opcode[31:26] rd[25:21] rs1[20:16] rs2[15:11] func[10:0]",
