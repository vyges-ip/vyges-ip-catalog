  },
  "architecture": {
    "type": "cpu",
    "features": [
      "RV32IMC instruction set (Integer, Multiply, Compressed)",
      "2-stage pipeline (IF/ID+EX), configurable to 3-stage with WritebackStage",
      "Configurable register file: FF (ASIC), FPGA, or latch",
      "Optional PMP (Physical Memory Protection, up to 16 regions)",
      "Optional instruction cache (ICache, 4KB default)",
      "Branch predictor (configurable)",
      "SecureIbex: lockstep core + shadow registers for fault detection",
      "Full RISC-V Debug Spec support (halt, resume, single-step, breakpoints)",
      "Hardware performance counters (mcycle, minstret)",
      "Scramble key interface for memory encryption",
      "30 RTL files, 19,627 lines"
    ]
  },
