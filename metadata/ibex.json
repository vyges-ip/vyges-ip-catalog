          "direction": "output",
          "type": "control",
          "width": 4
        },
        {
          "name": "wdata_o",
          "direction": "output",
          "type": "data",
          "width": 32
        },
        {
          "name": "rvalid_i",
          "direction": "input",
          "type": "control",
          "width": 1
        },
        {
          "name": "rdata_i",
          "direction": "input",
          "type": "data",
          "width": 32
        }
      ]
    },
    {
      "type": "interrupt",
      "direction": "input",
      "protocol": "level",
      "description": "irq_software_i, irq_timer_i, irq_external_i, irq_fast_i[14:0], irq_nm_i"
    },
    {
      "type": "debug",
      "direction": "input",
      "description": "debug_req_i for JTAG halt/resume"
    }
  ],
  "parameters": [
    {
      "name": "PMPEnable",
      "type": "bit",
      "default": "1'b0",
      "description": "Enable Physical Memory Protection"
    },
    {
      "name": "RV32M",
      "type": "enum",
      "default": "RV32MFast",
      "description": "Multiply/divide: RV32MNone, RV32MSlow, RV32MFast, RV32MSingleCycle"
    },
    {
      "name": "RV32B",
      "type": "enum",
      "default": "RV32BNone",
      "description": "Bit manipulation: RV32BNone, RV32BBalanced, RV32BFull"
    },
    {
      "name": "RegFile",
      "type": "enum",
      "default": "RegFileFF",
      "description": "Register file: RegFileFF (ASIC), RegFileFPGA, RegFileLatch"
    },
    {
      "name": "ICache",
      "type": "bit",
      "default": "1'b0",
      "description": "Enable instruction cache"
    },
    {
      "name": "BranchPredictor",
      "type": "bit",
      "default": "1'b0",
      "description": "Enable branch predictor"
    },
    {
      "name": "SecureIbex",
      "type": "bit",
      "default": "1'b0",
      "description": "Enable lockstep + shadow registers"
    },
    {
      "name": "WritebackStage",
      "type": "bit",
      "default": "1'b0",
      "description": "Enable 3rd pipeline stage (writeback)"
    },
    {
      "name": "BranchTargetALU",
      "type": "bit",
      "default": "1'b0",
      "description": "Dedicated branch target ALU"
    }
  ],
