      "signals": [
        {
          "name": "req_o",
          "direction": "output",
          "type": "control",
          "width": 1
        },
        {
          "name": "gnt_i",
          "direction": "input",
          "type": "control",
          "width": 1
        },
        {
          "name": "addr_o",
          "direction": "output",
          "type": "address",
