  },
  "architecture": {
    "type": "peripheral",
    "features": [
      "HMAC-384 and HMAC-512 message authentication (RFC 2104)",
      "Masked SHA-512 core for side-channel resistance",
      "12 LFSR entropy generators (384-bit total entropy)",
      "4-state FSM: IDLE, IPAD, OPAD, HMAC, DONE",
      "Key XOR with IPAD (0x36) and OPAD (0x5C) padding",
      "Software-written keys or CSR-provided keys",
      "KeyVault 2-port read (key + block) and 1-port write (tag)",
      "Zeroize on command or debug unlock",
      "OCP lock awareness",
      "PeakRDL-generated register file"
    ]
