  "interfaces": [
    {
      "type": "bus",
      "direction": "slave",
      "protocol": "AHB-Lite",
      "port": "ahb",
      "width": 32,
      "description": "AHB-Lite slave via hmac_ctrl wrapper. 32-bit address and data."
    },
    {
      "type": "keyvault",
      "direction": "both",
      "protocol": "kv_read/kv_write",
      "port": "kv",
      "description": "KeyVault: 2 read ports (key + message block) and 1 write port (HMAC tag)."
    },
    {
      "type": "sideload",
      "direction": "input",
      "protocol": "caliptra_csr",
      "port": "cptra_csr_hmac_key",
      "width": 512,
      "description": "Direct HMAC key input from Caliptra CSR (16 x 32-bit dwords)."
    },
    {
      "type": "interrupt",
      "direction": "output",
      "port": "error_intr",
      "description": "Error interrupt (key zero, key mode error)."
    },
    {
      "type": "interrupt",
      "direction": "output",
      "port": "notif_intr",
      "description": "Completion notification interrupt (cmd done)."
    },
    {
      "type": "status",
      "direction": "output",
      "port": "busy_o",
      "description": "HMAC engine busy indicator."
    },
    {
      "type": "clock",
      "direction": "input",
      "port": "clk",
      "description": "System clock."
    },
    {
      "type": "reset",
      "direction": "input",
      "port": "reset_n",
      "polarity": "active_low",
      "description": "Asynchronous active-low reset."
    }
  ],
  "parameters": [
    {
      "name": "ADDR_WIDTH",
      "type": "int",
      "default": 32,
      "description": "Address bus width."
    },
    {
